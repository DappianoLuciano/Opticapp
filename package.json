{
  "name": "opticapp",
  "version": "1.2.0",
  "description": "Sistema de gestión para ópticas",
  "main": "main/main.js",
  "scripts": {
    "dev:renderer": "npm --prefix renderer run dev",
    "dev:electron": "wait-on http://localhost:5173 && electron .",
    "dev": "concurrently -k \"npm run dev:renderer\" \"npm run dev:electron\"",
    "build:renderer": "npm --prefix renderer run build",
    "build": "npm run build:renderer && electron-builder",
    "dist": "npm run build:renderer && electron-builder --win",
    "release": "npm run build:renderer && electron-builder --win --publish always",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:smoke": "playwright test tests/smoke.spec.js",
    "test:report": "playwright show-report"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^6.15.0",
    "electron-updater": "^6.8.3",
    "prisma": "^6.15.0",
    "qrcode": "^1.5.4",
    "whatsapp-web.js": "^1.34.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "concurrently": "^9.2.1",
    "electron": "^40.4.0",
    "electron-builder": "^25.1.8",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.opticapp.app",
    "productName": "OpticApp",
    "asar": false,
    "files": [
      "main/**/*",
      "renderer/dist/**/*",
      "node_modules/**/*",
      "node_modules/.prisma/**/*",
      "!node_modules/.cache"
    ],
    "extraResources": [
      {
        "from": "prisma/schema.prisma",
        "to": "prisma/schema.prisma"
      },
      {
        "from": "prisma/migrations",
        "to": "prisma/migrations"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "OpticApp"
    },
    "directories": {
      "output": "dist-electron"
    },
    "publish": {
      "provider": "github",
      "owner": "DappianoLuciano",
      "repo": "opticapp"
    }
  }
}
